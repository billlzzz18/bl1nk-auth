# bl1nk-auth Environment Configuration
# Copy this file to .env and fill in the values

# ────────────────────────────────────────────────
# Application Settings
# ────────────────────────────────────────────────
# The issuer URL for JWT tokens (your app's base URL)
AUTH_ISSUER=http://localhost:3000

# The audience for JWT tokens
AUTH_AUDIENCE=auth

# ────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bl1nk_auth

# ────────────────────────────────────────────────
# JWT Keys (RS256)
# ────────────────────────────────────────────────
# Generate keys with: npm run gen:key
AUTH_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
AUTH_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional: Key ID for JWKS
AUTH_KEY_KID=dev-key-1

# ────────────────────────────────────────────────
# GitHub OAuth
# ────────────────────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# ────────────────────────────────────────────────
# Google OAuth
# ────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ────────────────────────────────────────────────
# Optional Settings
# ────────────────────────────────────────────────
# Skip environment validation during build
SKIP_ENV_VALIDATION=false

# Node environment
NODE_ENV=development
